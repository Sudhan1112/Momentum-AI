{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "next": [
        "./node_modules/next",
        "../../node_modules/next"
      ],
      "next/*": [
        "./node_modules/next/*",
        "../../node_modules/next/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "..\\..\\..\\..\\..\\..\\..\\tmp\\Momentum-AI-next-web\\types\\**\\*.ts",
    "..\\..\\..\\..\\..\\AppData\\Local\\Temp\\Momentum-AI-next-web/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
