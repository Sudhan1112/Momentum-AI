# ==========================================
# web / Next.js — copy into apps/web/.env.local
# ==========================================

# Supabase project URL (found in Supabase dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"

# Supabase anon/public key (safe to expose client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# URL of the deployed sync-server (Render / Railway / etc.)
NEXT_PUBLIC_SYNC_SERVER_URL="https://your-sync-server.onrender.com"

# Supabase service-role key — SERVER ONLY, never expose to browser
SUPABASE_SERVICE_KEY="your-supabase-service-role-key"

# Gemini API key for Momentum AI route handlers — SERVER ONLY.
# Documented in Sprint 0 and intentionally unused until Sprint 3.
GEMINI_API_KEY="your-gemini-api-key"

# Optional server-side model override for Momentum AI route handlers.
# Documented in Sprint 0 and intentionally unused until Sprint 3.
MOMENTUM_AI_MODEL="gemini-1.5-flash"

# ==========================================
# sync-server — copy into apps/sync-server/.env
# ==========================================

PORT=4000

# Same Supabase project URL as above
SUPABASE_URL="https://your-project-ref.supabase.co"

# Same service-role key as above (sync-server needs it to verify JWTs)
SUPABASE_SERVICE_KEY="your-supabase-service-role-key"

# Comma-separated list of allowed CORS origins (your Vercel deployment URL)
CLIENT_URL="https://your-app.vercel.app"
